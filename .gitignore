# OS-specific
.DS_Store
.DS_Storage
**/.DS_Store
**/.DS_Storage
Thumbs.db
ehthumbs.db
desktop.ini

# Rust/Cargo
/target/
**/target/
/out/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Frontend build/test artifacts
**/node_modules/
**/dist/
**/build/
**/.vite/
**/.svelte-kit/
**/playwright-report/
**/test-results/
**/.playwright/
**/*-snapshots/
/scripts/out/

# Secrets / TLS keys (never commit)
server.key
server.crt
server.pem
*.pem
*.p12
*.pfx
/config/dev-certs/**
/config/local/**
!/config/local/
!/config/local/.gitkeep
# Explicit local-sensitive files (covered by /config/local/**, kept for clarity)
/config/local/admin-auth.json
/config/local/*.qkeys.json
/config/local/dev-certs/*.key
/config/local/dev-certs/*.crt

# Admin auth credentials (never commit - auto-generated on first start)
/config/admin-auth.json

# Admin runtime state
/config/*.runtime.json

# Server runtime state files (auto-generated, not for repo)
/config/*.logging.json
/config/*.qkeys.json

# Editor/IDE
/AGENTS.md
/.env
*.orig
*.bak

# Internal dev docs (not for public repo)
docs/changelog.md
docs/context.md
docs/todo.md
docs/todo/
/.env.*
*.tsbuildinfo
*.swp

# IDE/editor (future-proof)
.vscode/
.idea/
.claude/

# Env manager (future-proof)
.direnv/
.envrc

# Fuzz seed corpus and runtime artifacts (binary blobs, regenerated by cargo-fuzz)
/scripts/tests/fuzz/seeds/
/scripts/tests/fuzz/corpus/
/scripts/tests/fuzz/artifacts/

# Tool caches
**/.cache/
bun.lockb

# Coverage/profiling (future-proof)
coverage/
.nyc_output/
lcov.info
*.profraw
*.profdata

# macOS debug symbols outside target/scripts/out (future-proof)
**/*.dSYM/

