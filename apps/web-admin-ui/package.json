{
  "name": "quicfuscate-web-admin-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 1430 --strictPort",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 1431 --strictPort",
    "check": "tsc -b && vite build",
    "serve:codex": "tsc -b && vite build && echo \"Build OK. For a persistent server run: bun run dev (http://localhost:1430) or bun run preview (http://localhost:1431).\"",
    "test": "bun run test:e2e",
    "test:unit": "bun test ../../scripts/tests/frontend/web-admin/unit",
    "test:e2e": "NODE_PATH=./node_modules env -u NO_COLOR playwright test",
    "test:e2e:ui": "NODE_PATH=./node_modules env -u NO_COLOR playwright test --ui",
    "test:e2e:debug": "NODE_PATH=./node_modules env -u NO_COLOR playwright test --debug"
  },
  "dependencies": {
    "@heroui/button": "^2.2.31",
    "@heroui/react": "^2.8.8",
    "@heroui/theme": "^2.4.26",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.0",
    "jotai": "^2.11.1",
    "liquid-glass-react": "^1.1.1",
    "lucide-react": "^0.474.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.0.6",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react-swc": "^3.7.2",
    "tailwindcss": "^4.0.6",
    "typescript": "~5.7.2",
    "vite": "^6.1.0"
  }
}
