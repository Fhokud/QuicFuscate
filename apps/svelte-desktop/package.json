{
  "name": "quicfuscate-svelte-desktop",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 4173 --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "serve:codex": "bun run build && echo \"Build OK. For a persistent server run: bun run dev (http://localhost:4173) or bun run preview with explicit --port/--host flags.\"",
    "test": "bun run test:unit",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:unit:watch": "vitest --config vitest.config.ts --watch",
    "test:e2e": "NODE_PATH=./node_modules env -u NO_COLOR -u FORCE_COLOR playwright test",
    "test:e2e:ui": "NODE_PATH=./node_modules env -u NO_COLOR -u FORCE_COLOR playwright test --ui",
    "test:e2e:debug": "NODE_PATH=./node_modules env -u NO_COLOR -u FORCE_COLOR playwright test --debug"
  },
  "dependencies": {
    "@quicfuscate/theme": "workspace:*",
    "@quicfuscate/ui": "workspace:*",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-updater": "2",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "@lucide/svelte": "^0.577.0",
    "tailwind-merge": "^3.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.2.8",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.0.6",
    "jsdom": "^28.0.0",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "tailwindcss": "^4.0.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
